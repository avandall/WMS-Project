# Example environment file (do not put secrets here).
#
# Copy to `.env` and fill in real values.

# Database Configuration
DATABASE_URL=postgresql://wms_user:CHANGE_ME@localhost:5433/warehouse_db

# Database Connection Pool Settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Application Settings
DEBUG=False
TITLE=Warehouse Management API
VERSION=1.0.0
DESCRIPTION=A FastAPI application for warehouse management

# Server Settings
HOST=0.0.0.0
PORT=8080

# API Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Security Settings
SECRET_KEY=CHANGE_ME
API_KEY_HEADER=X-API-Key

# CORS Settings
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
