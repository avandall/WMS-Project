    def test_operator_order_fulfillment_journey(self, mock_all_services, operator_user, sample_products, sample_warehouses):
        """Test operator journey: Customer order fulfillment"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        inventory_items = [
            InventoryItem(product_id=1, quantity=100),
            InventoryItem(product_id=2, quantity=50),
            InventoryItem(product_id=3, quantity=25)
        ]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['product_service'].get_product_details.side_effect = sample_products
        services['warehouse_service'].get_warehouse_inventory.return_value = inventory_items
        services['document_service'].create_export_document.return_value = Document(
            document_id=1, doc_type=DocumentType.EXPORT, from_warehouse_id=1,
            items=[], created_by="operator"
        )# Create a mock document that will be returned after posting
posted_document = Document(
    document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
    created_by="manager"
)
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services[\'document_service\'].post_document.return_value = posted_document
        
        # Journey: Operator fulfills customer orders
        journey_steps = []
        
        # Step 1: Operator logs in
        services['user_service'].authenticate.return_value = operator_user
        authenticated_user = services['user_service'].authenticate("operator@wms.com", "password")
        journey_steps.append(f"Operator logged in: {authenticated_user.email}")
        
        # Step 2: Receive order assignment
        customer_order = {
            "order_id": "ORD-12345",
            "customer": "ABC Corporation",
            "items": [
                {"product_id": 1, "quantity": 2, "unit_price": 999.99},
                {"product_id": 2, "quantity": 5, "unit_price": 299.99}
            ],
            "priority": "NORMAL"
        }
        
        journey_steps.append(f"Received order assignment: {customer_order['order_id']}")
        
        # Step 3: Verify product availability
        available_items = []
        unavailable_items = []
        
        for item in customer_order["items"]:
            product = services['product_service'].get_product_details(item["product_id"])
            inventory = services['warehouse_service'].get_warehouse_inventory(1)
            
            available_qty = next((inv.quantity for inv in inventory if inv.product_id == item["product_id"]), 0)
            
            if available_qty >= item["quantity"]:
                available_items.append(item)
                journey_steps.append(f"Verified availability: {product.name} - {available_qty} available, need {item['quantity']}")
            else:
                unavailable_items.append(item)
                journey_steps.append(f"Insufficient stock: {product.name} - {available_qty} available, need {item['quantity']}")
        
        # Step 4: Process order if all items available
        if not unavailable_items:
            # Create export document
            document = services['document_service'].create_export_document(
                from_warehouse_id=1,
                items=available_items,
                created_by="operator",
                note=f"Customer order {customer_order['order_id']}"
            )
            journey_steps.append(f"Created export document: {document.document_id}")
            
            # Step 5: Pick items from warehouse
            picked_items = []
            for item in available_items:
                product = services['product_service'].get_product_details(item["product_id"])
                journey_steps.append(f"Picked {item['quantity']} x {product.name}")
                picked_items.append(item)
            
            # Step 6: Pack order
            packed_order = {
                "order_id": customer_order["order_id"],
                "items": picked_items,
                "packed_by": authenticated_user.email,
                "packed_at": datetime.now()
            }
            journey_steps.append(f"Packed order: {len(picked_items)} items")
            
            # Step 7: Post document (confirm shipment)
            posted_document = services['document_service'].post_document(document.document_id, "operator")
            journey_steps.append(f"Shipped order: {posted_document.status}")
            
            # Step 8: Generate packing slip
            packing_slip = {
                "order_id": customer_order["order_id"],
                "customer": customer_order["customer"],
                "items": picked_items,
                "total_value": sum(item["quantity"] * item["unit_price"] for item in picked_items),
                "shipped_by": authenticated_user.email,
                "shipped_at": datetime.now()
            }
            journey_steps.append(f"Generated packing slip for order {customer_order['order_id']}")
            
        else:
            journey_steps.append(f"Order could not be fulfilled: {len(unavailable_items)} items unavailable")
        
        # Verify journey completion
        if not unavailable_items:
            assert posted_document.status == DocumentStatus.POSTED
            assert len(available_items) == 2
        
        # Print journey summary
        print("\n=== Operator Order Fulfillment Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    def test_operator_receiving_process_journey(self, mock_all_services, operator_user, sample_products, sample_warehouses):
        """Test operator journey: Receiving and stocking process"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['product_service'].get_product_details.side_effect = sample_products
        services['document_service'].create_import_document.return_value = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            items=[], created_by="operator"
        )# Create a mock document that will be returned after posting
posted_document = Document(
    document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
    created_by="manager"
)
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services[\'document_service\'].post_document.return_value = posted_document
        
        # Journey: Operator receives and stocks incoming shipment
        journey_steps = []
        
        # Step 1: Operator logs in
        services['user_service'].authenticate.return_value = operator_user
        authenticated_user = services['user_service'].authenticate("operator@wms.com", "password")
        journey_steps.append(f"Operator logged in: {authenticated_user.email}")
        
        # Step 2: Receive shipment notification
        incoming_shipment = {
            "shipment_id": "SHP-67890",
            "supplier": "Tech Suppliers Inc",
            "expected_items": [
                {"product_id": 4, "quantity": 10, "unit_price": 199.99},
                {"product_id": 5, "quantity": 25, "unit_price": 89.99}
            ],
            "tracking_number": "TN123456789",
            "estimated_arrival": datetime.now()
        }
        
        journey_steps.append(f"Received shipment notification: {incoming_shipment['shipment_id']}")
        
        # Step 3: Verify shipment arrival
        actual_items = incoming_shipment["expected_items"]  # Assume all items arrived
        journey_steps.append(f"Verified shipment arrival: {len(actual_items)} items received")
        
        # Step 4: Inspect items for quality
        inspected_items = []
        for item in actual_items:
            product = services['product_service'].get_product_details(item["product_id"])
            # Simulate quality inspection
            quality_status = "PASS"
            journey_steps.append(f"Inspected {item['quantity']} x {product.name} - Status: {quality_status}")
            inspected_items.append(item)
        
        # Step 5: Create receiving document
        document = services['document_service'].create_import_document(
            to_warehouse_id=1,
            items=inspected_items,
            created_by="operator",
            note=f"Receiving shipment {incoming_shipment['shipment_id']}"
        )
        journey_steps.append(f"Created receiving document: {document.document_id}")
        
        # Step 6: Stock items in warehouse
        stocked_items = []
        for item in inspected_items:
            product = services['product_service'].get_product_details(item["product_id"])
            
            # Simulate finding storage location
            storage_location = f"Aisle-{item['product_id']}-Shelf-1"
            journey_steps.append(f"Stocked {item['quantity']} x {product.name} at {storage_location}")
            stocked_items.append(item)
        
        # Step 7: Post receiving document
        posted_document = services['document_service'].post_document(document.document_id, "operator")
        journey_steps.append(f"Posted receiving document: {posted_document.status}")
        
        # Step 8: Generate receiving report
        receiving_report = {
            "shipment_id": incoming_shipment["shipment_id"],
            "supplier": incoming_shipment["supplier"],
            "received_by": authenticated_user.email,
            "received_at": datetime.now(),
            "items_received": len(stocked_items),
            "total_value": sum(item["quantity"] * item["unit_price"] for item in stocked_items),
            "storage_locations": [f"Aisle-{item['product_id']}-Shelf-1" for item in stocked_items]
        }
        journey_steps.append(f"Generated receiving report for shipment {incoming_shipment['shipment_id']}")
        
        # Step 9: Update inventory records
        for item in stocked_items:
            journey_steps.append(f"Updated inventory records: Product {item['product_id']} +{item['quantity']}")
        
        # Verify journey completion
        assert posted_document.status == DocumentStatus.POSTED
        assert len(inspected_items) == 2
        assert len(stocked_items) == 2
        
        # Print journey summary
        print("\n=== Operator Receiving Process Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    # ============================================================================
    # MULTI-USER COLLABORATION JOURNEYS
    # ============================================================================

    def test_multi_user_order_processing_journey(self, mock_all_services, admin_user, warehouse_manager_user, operator_user, sample_products, sample_warehouses):
        """Test multi-user journey: Collaborative order processing"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        inventory_items = [
            InventoryItem(product_id=1, quantity=100),
            InventoryItem(product_id=2, quantity=50)
        ]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['product_service'].get_product_details.side_effect = sample_products
        services['warehouse_service'].get_warehouse_inventory.return_value = inventory_items
        services['document_service'].create_export_document.return_value = Document(
            document_id=1, doc_type=DocumentType.EXPORT, from_warehouse_id=1,
            items=[], created_by="operator"
        )# Create a mock document that will be returned after posting
posted_document = Document(
    document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
    created_by="manager"
)
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services[\'document_service\'].post_document.return_value = posted_document
        
        # Journey: Multiple users collaborate on order processing
        journey_steps = []
        
        # Step 1: Admin creates high-priority order
        services['user_service'].authenticate.return_value = admin_user
        admin = services['user_service'].authenticate("admin@wms.com", "password")
        journey_steps.append(f"Admin logged in: {admin.email}")
        
        high_priority_order = {
            "order_id": "ORD-HIGH-001",
            "customer": "Priority Customer Inc",
            "items": [{"product_id": 1, "quantity": 10, "unit_price": 999.99}],
            "priority": "HIGH"
        }
        
        journey_steps.append(f"Admin created high-priority order: {high_priority_order['order_id']}")
        
        # Step 2: Manager assigns order to operator
        services['user_service'].authenticate.return_value = warehouse_manager_user
        manager = services['user_service'].authenticate("manager@wms.com", "password")
        journey_steps.append(f"Manager logged in: {manager.email}")
        
        # Assign order to operator
        assignment = {
            "order_id": high_priority_order["order_id"],
            "assigned_to": operator_user.email,
            "assigned_by": manager.email,
            "assigned_at": datetime.now()
        }
        journey_steps.append(f"Manager assigned order to: {assignment['assigned_to']}")
        
        # Step 3: Operator processes order
        services['user_service'].authenticate.return_value = operator_user
        operator = services['user_service'].authenticate("operator@wms.com", "password")
        journey_steps.append(f"Operator logged in: {operator.email}")
        
        # Check availability
        inventory = services['warehouse_service'].get_warehouse_inventory(1)
        available_qty = next((inv.quantity for inv in inventory if inv.product_id == 1), 0)
        journey_steps.append(f"Operator checked availability: {available_qty} units available")
        
        # Create export document
        document = services['document_service'].create_export_document(
            from_warehouse_id=1,
            items=high_priority_order["items"],
            created_by="operator",
            note=f"Priority order {high_priority_order['order_id']}"
        )
        journey_steps.append(f"Operator created export document: {document.document_id}")
        
        # Step 4: Manager approves expedited shipping
        approval = {
            "document_id": document.document_id,
            "approved_by": manager.email,
            "approved_at": datetime.now(),
            "expedited_shipping": True
        }
        journey_steps.append(f"Manager approved expedited shipping: {approval['document_id']}")
        
        # Step 5: Operator fulfills and ships order
        posted_document = services['document_service'].post_document(document.document_id, "operator")
        journey_steps.append(f"Operator shipped order: {posted_document.status}")
        
        # Step 6: Admin monitors order status
        services['user_service'].authenticate.return_value = admin_user
        admin = services['user_service'].authenticate("admin@wms.com", "password")
        journey_steps.append(f"Admin logged in to monitor: {admin.email}")
        
        order_status = {
            "order_id": high_priority_order["order_id"],
            "status": "SHIPPED",
            "shipped_at": datetime.now(),
            "tracking_number": "TN987654321",
            "expedited": True
        }
        journey_steps.append(f"Order status: {order_status['status']} (Expedited)")
        
        # Step 7: Generate collaboration report
        collaboration_report = {
            "order_id": high_priority_order["order_id"],
            "participants": [
                {"role": "Admin", "user": admin.email, "action": "Created order"},
                {"role": "Manager", "user": manager.email, "action": "Assigned and approved"},
                {"role": "Operator", "user": operator.email, "action": "Processed and shipped"}
            ],
            "processing_time": "2 hours",
            "priority_level": "HIGH",
            "expedited_shipping": True
        }
        
        journey_steps.append(f"Generated collaboration report")
        
        # Verify journey completion
        assert posted_document.status == DocumentStatus.POSTED
        assert len(journey_steps) >= 7
        
        # Print journey summary
        print("\n=== Multi-User Order Processing Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    def test_emergency_stock_replenishment_journey(self, mock_all_services, admin_user, warehouse_manager_user, operator_user, sample_products, sample_warehouses):
        """Test multi-user journey: Emergency stock replenishment"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['warehouse_service'].get_warehouse_inventory.return_value = [
            InventoryItem(product_id=1, quantity=5)  # Critical low stock
        ]
        services['document_service'].create_import_document.return_value = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            items=[], created_by="manager"
        )# Create a mock document that will be returned after posting
posted_document = Document(
    document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
    created_by="manager"
)
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services[\'document_service\'].post_document.return_value = posted_document
        
        # Journey: Emergency stock replenishment
        journey_steps = []
        
        # Step 1: System detects critical stock level
        critical_stock_alert = {
            "product_id": 1,
            "product_name": "Laptop Computer",
            "current_quantity": 5,
            "minimum_quantity": 20,
            "alert_level": "CRITICAL"
        }
        journey_steps.append(f"Critical stock alert: {critical_stock_alert['product_name']} - {critical_stock_alert['current_quantity']} units")
        
        # Step 2: Manager receives alert and initiates emergency replenishment
        services['user_service'].authenticate.return_value = warehouse_manager_user
        manager = services['user_service'].authenticate("manager@wms.com", "password")
        journey_steps.append(f"Manager logged in: {manager.email}")
        
        emergency_order = {
            "order_id": "EMERGENCY-001",
            "supplier": "Tech Suppliers Inc",
            "items": [{"product_id": 1, "quantity": 100, "unit_price": 999.99}],
            "priority": "EMERGENCY",
            "expedited_shipping": True
        }
        journey_steps.append(f"Manager initiated emergency order: {emergency_order['order_id']}")
        
        # Step 3: Admin approves emergency purchase
        services['user_service'].authenticate.return_value = admin_user
        admin = services['user_service'].authenticate("admin@wms.com", "password")
        journey_steps.append(f"Admin logged in: {admin.email}")
        
        approval = {
            "order_id": emergency_order["order_id"],
            "approved_by": admin.email,
            "approved_amount": 99999.00,
            "justification": "Critical stock replenishment"
        }
        journey_steps.append(f"Admin approved emergency purchase: ${approval['approved_amount']}")
        
        # Step 4: Supplier ships emergency order
        shipment_arrival = {
            "shipment_id": "EMERGENCY-SHIP-001",
            "order_id": emergency_order["order_id"],
            "arrival_time": datetime.now(),
            "expedited": True
        }
        journey_steps.append(f"Emergency shipment arrived: {shipment_arrival['shipment_id']}")
        
        # Step 5: Operator receives emergency shipment immediately
        services['user_service'].authenticate.return_value = operator_user
        operator = services['user_service'].authenticate("operator@wms.com", "password")
        journey_steps.append(f"Operator logged in: {operator.email}")
        
        # Create emergency receiving document
        document = services['document_service'].create_import_document(
            to_warehouse_id=1,
            items=emergency_order["items"],
            created_by="operator",
            note=f"Emergency replenishment - {emergency_order['order_id']}"
        )
        journey_steps.append(f"Operator created emergency receiving document: {document.document_id}")
        
        # Step 6: Immediate processing and stocking
        posted_document = services['document_service'].post_document(document.document_id, "operator")
        journey_steps.append(f"Emergency stock processed: {posted_document.status}")
        
        # Step 7: Verify stock level restored
        services['warehouse_service'].get_warehouse_inventory.return_value = [
            InventoryItem(product_id=1, quantity=105)  # Restocked
        ]
        
        final_inventory = services['warehouse_service'].get_warehouse_inventory(1)
        final_quantity = final_inventory[0].quantity if final_inventory else 0
        journey_steps.append(f"Stock level restored: {final_quantity} units")
        
        # Step 8: Generate emergency replenishment report
        emergency_report = {
            "alert_triggered_at": datetime.now(),
            "resolved_at": datetime.now(),
            "resolution_time": "4 hours",
            "participants": [admin.email, manager.email, operator.email],
            "cost": approval["approved_amount"],
            "stock_before": critical_stock_alert["current_quantity"],
            "stock_after": final_quantity,
            "success": True
        }
        
        journey_steps.append(f"Generated emergency replenishment report")
        
        # Verify journey completion
        assert posted_document.status == DocumentStatus.POSTED
        assert final_quantity == 105
        assert final_quantity > critical_stock_alert["minimum_quantity"]
        
        # Print journey summary
        print("\n=== Emergency Stock Replenishment Journey ===")
        for step in journey_steps:
            print(f"  {step}")
