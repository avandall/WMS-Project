    def test_warehouse_manager_daily_operations_journey(self, mock_all_services, warehouse_manager_user, sample_products, sample_warehouses):
        """Test warehouse manager journey: Daily operations management"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        inventory_items = [
            InventoryItem(product_id=1, quantity=100),
            InventoryItem(product_id=2, quantity=50),
            InventoryItem(product_id=3, quantity=25)
        ]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['warehouse_service'].get_warehouse_inventory.return_value = inventory_items
        services['inventory_service'].get_low_stock_products.return_value = [
            {"product": sample_products[2], "current_quantity": 25, "threshold": 30, "needs_restock": True}
        ]
        services['document_service'].create_import_document.return_value = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            items=[], created_by="manager"
        )
        # Create a mock document that will be returned after posting
        posted_document = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            created_by="manager"
        )
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services['document_service'].post_document.return_value = posted_document
        
        # Journey: Warehouse manager performs daily operations
        journey_steps = []
        
        # Step 1: Manager logs in
        services['user_service'].authenticate.return_value = warehouse_manager_user
        authenticated_user = services['user_service'].authenticate("manager@wms.com", "password")
        journey_steps.append(f"Manager logged in: {authenticated_user.email}")
        
        # Step 2: Check warehouse status
        warehouse_status = services['warehouse_service'].get_warehouse(1)
        journey_steps.append(f"Checked warehouse: {warehouse_status.location}")
        
        # Step 3: Review inventory levels
        current_inventory = services['warehouse_service'].get_warehouse_inventory(1)
        total_items = sum(item.quantity for item in current_inventory)
        journey_steps.append(f"Reviewed inventory: {total_items} total items across {len(current_inventory)} products")
        
        # Step 4: Check for low stock alerts
        low_stock_alerts = services['inventory_service'].get_low_stock_products(threshold=30)
        journey_steps.append(f"Low stock alerts: {len(low_stock_alerts)} products need restocking")
        
        # Step 5: Process incoming shipment
        incoming_shipment = [
            {"product_id": 3, "quantity": 50, "unit_price": 49.99}  # Restock low stock item
        ]
        
        document = services['document_service'].create_import_document(
            to_warehouse_id=1,
            items=incoming_shipment,
            created_by="manager",
            note="Restocking low stock items"
        )
        journey_steps.append(f"Created import document for incoming shipment: {document.document_id}")
        
        # Step 6: Receive and post shipment
        posted_document = services['document_service'].post_document(document.document_id, "manager")
        journey_steps.append(f"Received and posted shipment: {posted_document.status}")
        
        # Step 7: Process customer orders
        customer_orders = [
            {"product_id": 1, "quantity": 5, "unit_price": 999.99},
            {"product_id": 2, "quantity": 3, "unit_price": 299.99}
        ]
        
        export_document = services['document_service'].create_export_document(
            from_warehouse_id=1,
            items=customer_orders,
            created_by="manager",
            note="Customer orders fulfillment"
        )
        journey_steps.append(f"Created export document for customer orders: {export_document.document_id}")
        
        posted_export = services['document_service'].post_document(export_document.document_id, "manager")
        journey_steps.append(f"Fulfilled customer orders: {posted_export.status}")
        
        # Step 8: Generate daily operations report
        daily_report = {
            "date": datetime.now().strftime("%Y-%m-%d"),
            "warehouse": warehouse.location,
            "starting_inventory": total_items,
            "items_received": 50,
            "items_shipped": 8,
            "ending_inventory": total_items + 50 - 8,
            "low_stock_alerts": len(low_stock_alerts),
            "orders_processed": 2
        }
        
        journey_steps.append(f"Generated daily operations report")
        
        # Verify journey completion
        assert posted_document.status == DocumentStatus.POSTED
        assert posted_export.status == DocumentStatus.POSTED
        assert len(low_stock_alerts) == 1
        
        # Print journey summary
        print("\n=== Warehouse Manager Daily Operations Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    def test_warehouse_manager_transfer_coordination_journey(self, mock_all_services, warehouse_manager_user, sample_products, sample_warehouses):
        """Test warehouse manager journey: Coordinating inter-warehouse transfers"""
        
        services = mock_all_services
        
        # Setup mocks
        source_warehouse = sample_warehouses[0]
        target_warehouse = sample_warehouses[1]
        
        services['warehouse_service'].get_warehouse.side_effect = [source_warehouse, target_warehouse]
        services['warehouse_service'].get_warehouse_inventory.side_effect = [
            [InventoryItem(product_id=1, quantity=100)],  # Source inventory
            [InventoryItem(product_id=1, quantity=20)]   # Target inventory
        ]
        
        transfer_document = Document(
            document_id=1, doc_type=DocumentType.TRANSFER,
            from_warehouse_id=1, to_warehouse_id=2,
            items=[DocumentProduct(product_id=1, quantity=30, unit_price=999.99)],
            created_by="manager"
        )
        
        services['document_service'].create_transfer_document.return_value = transfer_document
        services['document_service'].post_document.return_value = transfer_document
        # Set status to POSTED to simulate successful posting
        services['document_service'].post_document.return_value.status = DocumentStatus.POSTED
        
        # Journey: Warehouse manager coordinates inter-warehouse transfer
        journey_steps = []
        
        # Step 1: Manager logs in
        services['user_service'].authenticate.return_value = warehouse_manager_user
        authenticated_user = services['user_service'].authenticate("manager@wms.com", "password")
        journey_steps.append(f"Manager logged in: {authenticated_user.email}")
        
        # Step 2: Identify transfer need (target warehouse running low)
        source_inventory = services['warehouse_service'].get_warehouse_inventory(1)
        target_inventory = services['warehouse_service'].get_warehouse_inventory(2)
        
        source_qty = source_inventory[0].quantity if source_inventory else 0
        target_qty = target_inventory[0].quantity if target_inventory else 0
        
        journey_steps.append(f"Identified transfer need: Source has {source_qty}, Target has {target_qty}")
        
        # Step 3: Calculate transfer quantity
        transfer_quantity = min(30, source_qty)  # Transfer 30 or what's available
        journey_steps.append(f"Calculated transfer quantity: {transfer_quantity}")
        
        # Step 4: Create transfer document
        transfer_items = [{"product_id": 1, "quantity": transfer_quantity, "unit_price": 999.99}]
        document = services['document_service'].create_transfer_document(
            from_warehouse_id=1,
            to_warehouse_id=2,
            items=transfer_items,
            created_by="manager",
            note="Stock replenishment transfer"
        )
        journey_steps.append(f"Created transfer document: {document.document_id}")
        
        # Step 5: Coordinate with receiving warehouse
        receiving_manager = User(user_id=4, email="receiver@wms.com", hashed_password="hashed_password", role="warehouse_manager")
        journey_steps.append(f"Coordinated with receiving manager: {receiving_manager.email}")
        
        # Step 6: Execute transfer
        posted_document = services['document_service'].post_document(document.document_id, "manager")
        journey_steps.append(f"Executed transfer: {posted_document.status}")
        
        # Step 7: Confirm receipt
        confirmation_status = "RECEIVED"
        journey_steps.append(f"Transfer confirmed by receiving warehouse: {confirmation_status}")
        
        # Step 8: Update inventory records
        final_source_qty = source_qty - transfer_quantity
        final_target_qty = target_qty + transfer_quantity
        journey_steps.append(f"Updated inventory: Source={final_source_qty}, Target={final_target_qty}")
        
        # Step 9: Generate transfer report
        transfer_report = {
            "transfer_id": document.document_id,
            "date": datetime.now().strftime("%Y-%m-%d"),
            "from_warehouse": source_warehouse.location,
            "to_warehouse": target_warehouse.location,
            "product_id": 1,
            "quantity_transferred": transfer_quantity,
            "status": "COMPLETED",
            "initiated_by": authenticated_user.email
        }
        
        journey_steps.append(f"Generated transfer completion report")
        
        # Verify journey completion
        assert posted_document.status == DocumentStatus.POSTED
        assert transfer_quantity == 30
        assert final_source_qty == 70
        assert final_target_qty == 50
        
        # Print journey summary
        print("\n=== Warehouse Manager Transfer Coordination Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    # ============================================================================
