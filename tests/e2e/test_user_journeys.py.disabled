    def test_admin_complete_system_setup_journey(self, mock_all_services, admin_user, sample_products, sample_warehouses):
        """Test admin user journey: Complete system setup"""
        
        services = mock_all_services
        
        # Setup mocks for system setup
        services['product_service'].create_product.side_effect = sample_products
        services['warehouse_service'].create_warehouse.side_effect = sample_warehouses
        services['user_service'].create_user.return_value = admin_user
        
        # Journey: Admin sets up the entire system
        journey_steps = []
        
        # Step 1: Admin logs in
        services['user_service'].authenticate.return_value = admin_user
        authenticated_user = services['user_service'].authenticate("admin@wms.com", "password")
        journey_steps.append(f"Admin logged in: {authenticated_user.email}")
        
        # Step 2: Create initial products
        for product in sample_products:
            created_product = services['product_service'].create_product(
                product_id=product.product_id,
                name=product.name,
                description=product.description,
                price=product.price
            )
            journey_steps.append(f"Created product: {created_product.name}")
        
        # Step 3: Create warehouses
        for warehouse in sample_warehouses:
            created_warehouse = services['warehouse_service'].create_warehouse(warehouse.location)
            journey_steps.append(f"Created warehouse: {created_warehouse.location}")
        
        # Step 4: Create additional users
        warehouse_manager = User(user_id=2, email="manager@wms.com", hashed_password="hashed_password", role="warehouse_manager")
        operator = User(user_id=3, email="operator@wms.com", hashed_password="hashed_password", role="operator")
        
        services['user_service'].create_user.return_value = warehouse_manager
        services['user_service'].create_user(warehouse_manager.email, "password", "warehouse_manager")
        journey_steps.append(f"Created user: {warehouse_manager.email}")
        
        services['user_service'].create_user.return_value = operator
        services['user_service'].create_user(operator.email, "password", "operator")
        journey_steps.append(f"Created user: {operator.email}")
        
        # Step 5: Verify system setup
        services['product_service'].get_all_products.return_value = sample_products
        services['warehouse_service'].get_all_warehouses.return_value = sample_warehouses
        services['user_service'].list_users.return_value = [admin_user, warehouse_manager, operator]
        
        products = services['product_service'].get_all_products()
        warehouses = services['warehouse_service'].get_all_warehouses()
        users = services['user_service'].list_users()
        
        journey_steps.append(f"System setup complete: {len(products)} products, {len(warehouses)} warehouses, {len(users)} users")
        
        # Verify journey completion
        assert len(products) == 5
        assert len(warehouses) == 3
        assert len(users) == 3
        assert authenticated_user.role == "admin"
        
        # Print journey summary
        print("\n=== Admin System Setup Journey ===")
        for step in journey_steps:
            print(f"  {step}")

    def test_admin_inventory_reconciliation_journey(self, mock_all_services, admin_user, sample_products, sample_warehouses):
        """Test admin user journey: Monthly inventory reconciliation"""
        
        services = mock_all_services
        
        # Setup mocks
        warehouse = sample_warehouses[0]
        inventory_items = [
            InventoryItem(product_id=1, quantity=95),  # Expected 100, difference -5
            InventoryItem(product_id=2, quantity=55),  # Expected 50, difference +5
            InventoryItem(product_id=3, quantity=25),  # Expected 25, difference 0
        ]
        
        services['warehouse_service'].get_warehouse.return_value = warehouse
        services['warehouse_service'].get_warehouse_inventory.return_value = inventory_items
        services['document_service'].create_import_document.return_value = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            items=[], created_by="admin"
        )
        # Create a mock document that will be returned after posting
        posted_document = Document(
            document_id=1, doc_type=DocumentType.IMPORT, to_warehouse_id=1,
            created_by="admin"
        )
        # Simulate the posted document by setting its status
        posted_document.status = DocumentStatus.POSTED
        services['document_service'].post_document.return_value = posted_document
        
        # Journey: Admin performs monthly inventory reconciliation
        journey_steps = []
        
        # Step 1: Admin logs in and selects warehouse
        services['user_service'].authenticate.return_value = admin_user
        authenticated_user = services['user_service'].authenticate("admin@wms.com", "password")
        journey_steps.append(f"Admin logged in: {authenticated_user.email}")
        
        selected_warehouse = services['warehouse_service'].get_warehouse(1)
        journey_steps.append(f"Selected warehouse: {selected_warehouse.location}")
        
        # Step 2: Generate current inventory report
        current_inventory = services['warehouse_service'].get_warehouse_inventory(1)
        journey_steps.append(f"Current inventory: {len(current_inventory)} items")
        
        # Step 3: Perform physical count simulation
        physical_counts = {1: 100, 2: 50, 3: 25}  # Expected quantities
        journey_steps.append("Physical count completed")
        
        # Step 4: Calculate adjustments
        adjustments = []
        for item in current_inventory:
            expected = physical_counts.get(item.product_id, 0)
            actual = item.quantity
            difference = expected - actual
            
            if difference != 0:
                adjustments.append({
                    "product_id": item.product_id,
                    "adjustment": difference,
                    "type": "INCREASE" if difference > 0 else "DECREASE"
                })
        
        journey_steps.append(f"Calculated {len(adjustments)} adjustments needed")
        
        # Step 5: Create adjustment document
        if adjustments:
            adjustment_items = [
                {"product_id": adj["product_id"], "quantity": abs(adj["adjustment"]), "unit_price": 0.00}
                for adj in adjustments
            ]
            
            document = services['document_service'].create_import_document(
                to_warehouse_id=1,
                items=adjustment_items,
                created_by="admin",
                note="Monthly inventory reconciliation - June 2024"
            )
            journey_steps.append(f"Created adjustment document: {document.document_id}")
            
            # Step 6: Post adjustment document
            posted_document = services['document_service'].post_document(document.document_id, "admin")
            journey_steps.append(f"Posted adjustment document: {posted_document.status}")
        
        # Step 7: Generate reconciliation report
        reconciliation_report = {
            "warehouse": selected_warehouse.location,
            "date": datetime.now().strftime("%Y-%m-%d"),
            "total_items_checked": len(current_inventory),
            "adjustments_made": len(adjustments),
            "discrepancies": adjustments
        }
        
        journey_steps.append(f"Generated reconciliation report")
        
        # Verify journey completion
        assert len(adjustments) == 2
        assert posted_document.status == DocumentStatus.POSTED
        
        # Print journey summary
        print("\n=== Admin Inventory Reconciliation Journey ===")
        for step in journey_steps:
            print(f"  {step}")

